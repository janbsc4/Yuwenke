rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function owns(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validProgress(progressId) {
      let data = request.resource.data;
      return data.keys().hasAll([
          'cardId',
          'direction',
          'status',
          'clientUpdatedAt',
          'serverUpdatedAt',
          'schemaVersion'
        ])
        && data.keys().hasOnly([
          'cardId',
          'direction',
          'status',
          'clientUpdatedAt',
          'serverUpdatedAt',
          'schemaVersion'
        ])
        && data.cardId is string
        && data.cardId.matches('^FC[0-9]{3}$')
        && (data.direction == 'hanzi-es' || data.direction == 'es-hanzi')
        && (data.status == 'learning' || data.status == 'known')
        && data.clientUpdatedAt is timestamp
        && data.serverUpdatedAt is timestamp
        && data.serverUpdatedAt == request.time
        && data.schemaVersion is int
        && data.schemaVersion == 1
        && progressId == data.cardId + '_' + data.direction;
    }

    match /users/{uid}/progress/{progressId} {
      allow get, list: if owns(uid);
      allow create: if owns(uid) && validProgress(progressId);
      allow update: if owns(uid)
        && validProgress(progressId)
        && request.resource.data.clientUpdatedAt >= resource.data.clientUpdatedAt;
      allow delete: if owns(uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
